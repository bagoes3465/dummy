# ============ MEDIAPIPE FACE RECOGNITION (FREE) ============
MEDIAPIPE_ENABLED=true
MEDIAPIPE_MODEL_ASSETS_PATH=./node_modules/@mediapipe/tasks-vision/wasm

# ============ AZURE FACE API (Optional - Free tier: 30,000/month) ============
# Uncomment to enable emotion/expression analysis
# AZURE_FACE_API_ENABLED=false
# AZURE_FACE_API_ENDPOINT=https://YOUR_REGION.face.cognitive.microsoft.com/
# AZURE_FACE_API_KEY=your_azure_key_here

# ============ IMAGE PROCESSING ============
# Background removal (remove.bg - optional, has free tier)
# REMOVEBG_API_KEY=your_remove_bg_key_here
# REMOVEBG_API_ENABLED=false

# ============ APP CONFIGURATION ============
NODE_ENV=development
APP_PORT=3000

# ============ STORAGE ============
STORAGE_PATH=./uploads
STORAGE_TEMP_PATH=./uploads/temp

# ============ QR CODE ============
QR_CODE_SIZE=300
QR_CODE_ERROR_CORRECTION_LEVEL=H
